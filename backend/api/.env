# Modern Bank - Backend Environment
# Contains credentials for database and other systems

NODE_ENV=production
PORT=8080

# Frontend connectivity
FRONTEND_IP=192.168.1.10

# VULNERABILITY: Hardcoded Windows (Database VM) credentials
WINDOWS_HOST=192.168.1.50
WINDOWS_USER=Administrator
WINDOWS_PASS=ModernBank@2024!Admin
WINDOWS_DB=ModernBank

# Database credentials
DB_TYPE=MSSQL
DB_HOST=192.168.1.50
DB_PORT=1433
DB_USER=sa
DB_PASS=ModernBank@2024!Admin
DB_NAME=ModernBank

# API Configuration
API_KEY=super_secret_api_key_12345
JWT_SECRET=jwt_secret_key_change_me

# VULNERABILITY: SSH credentials to Database VM (for persistence/lateral movement)
SSH_HOST=192.168.1.50
SSH_USER=Administrator
SSH_PASS=ModernBank@2024!Admin
SSH_PORT=22

# Logging
LOG_LEVEL=debug
DEBUG=true
